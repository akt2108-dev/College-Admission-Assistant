# Railway / Supabase backend configuration
# Copy to backend/.env for local development only.
# In Railway, set these as service environment variables instead.

DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=replace-with-your-supabase-password
DB_HOST=replace-with-your-supabase-host
DB_PORT=5432

# Optional tuning
DB_MAX_CONNECTIONS=10

# Comma-separated list of allowed frontend origins
# Example:
# ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://www.yourdomain.com
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:3000
